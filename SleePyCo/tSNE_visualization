device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
model = MainModel(config)   # 保证和训练时一致
ckpt = torch.load("checkpoints/your_model.pth", map_location=device)
model.load_state_dict(ckpt)
model.to(device)
model.eval()

# ==== 2. 提取特征 ====
features, labels = [], []
with torch.no_grad():
    for X, y in test_loader:
        X = X.to(device)
        
        # 如果 forward 只返回 logits，需要在 MainModel 里加 extract_features
        feat, logits = model.extract_features(X)
        
